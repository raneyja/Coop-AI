PORT=8787
NODE_ENV=development
COOP_REQUIRE_API_AUTH=false
COOP_DEV_MODE=false
DATABASE_URL=postgres://coop:coop@localhost:5432/coopai
CREDENTIALS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# OpenAI (required for Pro Lightning Mode pgvector embeddings)
OPENAI_API_KEY=

# GitHub App (required for cloud Zero-Clone + indexing)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=coop-ai
GITHUB_WEBHOOK_SECRET=

# Public URL GitHub redirects to after install (setup URL)
WEBHOOK_DOMAIN=http://localhost:8787
