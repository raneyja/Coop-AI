PORT=8787
# Railway sets PORT automatically — do not override in Railway Variables.
NODE_ENV=development
# Local dev: false allows any Bearer token. Production deploys MUST set true.
COOP_REQUIRE_API_AUTH=false
COOP_DEV_MODE=false
DATABASE_URL=postgres://coop:coop@localhost:5432/coopai
# Railway: reference Postgres plugin DATABASE_URL on the API service (includes sslmode=require).

# Railway Phase 1 API service (set in Railway Variables, not here):
# JOBS_BACKEND=postgres
# GRAPH_CACHE_BACKEND=postgres
# JOBS_WORKERS=0
CREDENTIALS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# COOP_PLAN_QUOTA_DISABLED=true

# Free plan rolling AI token budget (Claude-style 5-hour window). 80,000 tokens ≈ 80 credits.
# Pro and Enterprise plans are unlimited. Set to 0 or disable above to turn off enforcement.
# COOP_FREE_TOKEN_LIMIT=80000
# COOP_FREE_ROLLING_WINDOW_MS=18000000
# COOP_VISION_TOKEN_MULTIPLIER=2

# LLM provider API keys (chat + autocomplete — routed server-side; not stored in the extension).
# Configure each provider you enable. Free-tier credits use per-model weights (see src/config/llmModels.ts).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# COOP_LLM_ALLOW_UNAPPROVED=true

# Do not set COOP_LLM_MOCK=true when using real keys above

# GitHub App (org-wide install — production)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=coop-ai
GITHUB_WEBHOOK_SECRET=

# GitHub OAuth App (browser sign-in — easier for local dev; use one of GitHub App or OAuth)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Public URL for OAuth callbacks and GitHub App setup (production: https://api.coop-ai.dev)
# Set WEBHOOK_DOMAIN or COOP_PUBLIC_BASE_URL (same value) on Railway.
WEBHOOK_DOMAIN=http://localhost:8787
COOP_PUBLIC_BASE_URL=

# Browser origins allowed to call /v1/* (admin portal). Comma-separated.
# Production example:
# COOP_CORS_ORIGINS=https://admin.coop-ai.dev,https://coop-ai.dev
# Local dev example:
# COOP_CORS_ORIGINS=http://localhost:3001

# Operator portal (ops.coop-ai.dev)
# COOP_OPS_PORTAL_URL defaults from COOP_PUBLIC_BASE_URL when unset.
# COOP_OPERATOR_ALLOWLIST_EMAILS is required in production.
# COOP_OPERATOR_ALLOWLIST_EMAILS=alice@coop-ai.dev,bob@coop-ai.dev
# COOP_OPERATOR_DEFAULT_ROLE=super_admin
# COOP_OPERATOR_SESSION_TTL_MS=43200000
# COOP_OPERATOR_OAUTH_STATE_SECRET=change-me
# Optional: use a dedicated Google OAuth client for operator sign-in.
# COOP_OPERATOR_GOOGLE_CLIENT_ID=
# COOP_OPERATOR_GOOGLE_CLIENT_SECRET=

# Checkout redirect targets + transactional email links (password reset, verify email).
# Production (required when COOP_EMAIL_MOCK=false):
# COOP_MARKETING_BASE_URL=https://coop-ai.dev
# COOP_CHECKOUT_SUCCESS_URL=https://coop-ai.dev/welcome
# COOP_CHECKOUT_CANCEL_URL=https://coop-ai.dev/pricing
# COOP_ADMIN_PORTAL_URL=https://admin.coop-ai.dev
# STRIPE_BILLING_PORTAL_RETURN_URL=https://admin.coop-ai.dev/billing
# Local dev with real email (same production URLs — reset/verify pages live on coop-ai.dev):
# COOP_MARKETING_BASE_URL=https://coop-ai.dev

# Stripe (Pro self-serve checkout)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=
# STRIPE_BILLING_PORTAL_RETURN_URL=https://admin.coop-ai.dev/billing

# Transactional email (Resend)
# RESEND_API_KEY=
# EMAIL_FROM=hello@coop-ai.dev
# COOP_EMAIL_MOCK=true

# Slack App (org OAuth — Find Owner presence + thread search)
SLACK_APP_CLIENT_ID=
SLACK_APP_CLIENT_SECRET=

# Atlassian 3LO (Jira + Confluence)
ATLASSIAN_APP_CLIENT_ID=
ATLASSIAN_APP_CLIENT_SECRET=

# Notion — internal integration (same token as scripts/populate_notion.py seeder)
NOTION_INTEGRATION_TOKEN=

# Notion OAuth (public integration — production Connect Notion)
NOTION_APP_CLIENT_ID=
NOTION_APP_CLIENT_SECRET=

# Google sign-in (admin portal + marketing — NOT the Docs Drive search client below)
# GOOGLE_AUTH_CLIENT_ID=
# GOOGLE_AUTH_CLIENT_SECRET=
# COOP_OAUTH_STATE_SECRET=change-me-to-a-long-random-secret
# Optional preview/admin origins for post-login redirects (comma-separated origins):
# COOP_AUTH_EXTRA_REDIRECT_ORIGINS=https://admin-git-preview.vercel.app
# Optional extra Google OAuth redirect URIs (comma-separated absolute callback URLs):
# GOOGLE_AUTH_EXTRA_REDIRECT_URIS=

# Google OAuth (Drive read — Google Docs search)
GOOGLE_DOCS_APP_CLIENT_ID=
GOOGLE_DOCS_APP_CLIENT_SECRET=

# Microsoft Entra / Graph OAuth (Teams message search)
# TEAMS_APP_CLIENT_ID = Application (client) ID from Azure Overview (UUID, e.g. 12345678-abcd-...)
# TEAMS_APP_CLIENT_SECRET = secret *Value* from Certificates & secrets (contains ~ — NOT the client ID)
TEAMS_APP_CLIENT_ID=
TEAMS_APP_CLIENT_SECRET=

# Lightning Mode — Zoekt full-text search
# ZOEKT_URL: HTTP endpoint of the Zoekt webserver (set automatically in docker-compose)
# ZOEKT_URL=http://zoekt:6070
#
# ZOEKT_INDEX_PATH: directory where the worker writes Zoekt index shards (worker only)
# ZOEKT_INDEX_PATH=/zoekt-indexes

# COOP_SSO_SP_ENTITY_ID=
# COOP_SSO_SESSION_TTL_MS=43200000
