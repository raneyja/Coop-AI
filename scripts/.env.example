# Bot token from your Slack app (xoxb-...). Used to seed demo threads.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Channel ID (not name) — copy from Slack: channel → View channel details → copy ID at bottom.
# Invite @Coupe AI Test Bot to this channel before running.
SLACK_CHANNEL_ID=C0123456789

# Optional: path to persona → user token map for posting as real users (xoxp-...).
# See user_tokens.json.example. Without this, all messages post as the bot app.
# SLACK_USER_TOKENS_FILE=user_tokens.json

# Delay range between messages (seconds)
SLACK_DELAY_MIN=1.5
SLACK_DELAY_MAX=4.0

# --- Jira demo seed (populate_jira.py) ---
# Same credentials as Coop AI Settings → Decision archaeology
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-atlassian-api-token
JIRA_PROJECT_KEY=COOP
# Repo owner for github:owner/repo lines in ticket descriptions
JIRA_DEMO_GITHUB_OWNER=coop-ai
# Seconds between create calls (avoid rate limits)
JIRA_DELAY_SEC=0.4

# --- Confluence demo seed (populate_confluence.py) ---
# Same Atlassian account as Jira; can reuse JIRA_* vars if unset.
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token
CONFLUENCE_SPACE_KEY=COOP
CONFLUENCE_SPACE_NAME=Coop AI Demo
# Repo owner for github:owner/repo lines in page bodies (match Settings → Repository)
CONFLUENCE_DEMO_GITHUB_OWNER=coop-ai
CONFLUENCE_DELAY_SEC=0.5
