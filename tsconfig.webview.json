{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ]
  },
  "include": [
    "src/webview/**/*",
    "src/chat/settingsScreens.ts",
    "src/chat/timezone.ts",
    "src/chat/quotaNotice.ts",
    "src/indexing/lightningTypes.ts",
    "src/types/decisionTimeline.ts"
  ],
  "exclude": [
    "**/* 2.*",
    "**/* 3.*",
    "**/* 4.*"
  ]
}
