# Coop API base (server-side checkout proxy — website/src/app/api/checkout/route.ts)
# Production: https://api.coopai.dev
# Local dev:   http://localhost:8787
COOP_API_BASE=http://localhost:8787

# Admin portal link on /welcome (client-visible)
# Production: https://admin.coop-ai.dev
# Local dev:   http://localhost:3001
NEXT_PUBLIC_ADMIN_PORTAL_URL=http://localhost:3001

# Google Apps Script web app URL for waitlist + demo form submissions
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional: Tawk.to live chat (free tier) — https://tawk.to
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# VS Code Marketplace URL (update when published)
NEXT_PUBLIC_VSCODE_MARKETPLACE_URL=
