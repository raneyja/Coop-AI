# Coop API base (server-side website API proxies)
# Used by:
# - website/src/app/api/checkout/route.ts
# - website/src/app/api/checkout-status/route.ts
# - website/src/app/api/signup/free/route.ts
# Production: https://api.coop-ai.dev
# Local dev:   http://localhost:8787
COOP_API_BASE=http://localhost:8787

# Optional fallback for routes that support a public-prefixed base.
# Keep this aligned with COOP_API_BASE.
NEXT_PUBLIC_COOP_API_BASE=http://localhost:8787

# Admin portal base URL on /welcome (client-visible; /login appended automatically)
# Must match backend COOP_ADMIN_PORTAL_URL (same host, no path)
# Production: https://admin.coop-ai.dev
# Local dev:   http://localhost:3001  (run website OR admin on 3001, not both)
NEXT_PUBLIC_ADMIN_PORTAL_URL=http://localhost:3001

# Google Apps Script web app URL for waitlist + demo form submissions
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional: Tawk.to live chat (free tier) — https://tawk.to
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# VS Code Marketplace URL (update when published)
NEXT_PUBLIC_VSCODE_MARKETPLACE_URL=

# Google Search Console HTML tag verification (optional)
# Search Console → Settings → Ownership verification → HTML tag → content="..."
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
